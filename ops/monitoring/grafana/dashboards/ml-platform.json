{
  "dashboard": {
    "id": null,
    "title": "ML Platform Monitoring",
    "tags": ["ml", "platform", "monitoring"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "MLFlow Server Status",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"mlflow\"}",
            "legendFormat": "MLFlow"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Jupyter Server Status",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"jupyter\"}",
            "legendFormat": "Jupyter"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "CPU Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total[5m]) * 100",
            "legendFormat": "{{job}}"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Memory Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "process_resident_memory_bytes / 1024 / 1024",
            "legendFormat": "{{job}} (MB)"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16}
      }
    ]
  }
}
